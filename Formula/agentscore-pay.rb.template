#
# DO NOT EDIT THIS FILE DIRECTLY -- this is the SOURCE TEMPLATE in
# agentscore/pay. The publish workflow substitutes ${URL} + ${SHA} and
# commits the rendered file into agentscore/homebrew-tap on each release.
# Homebrew derives the version from the URL.
#
class AgentscorePay < Formula
  desc "CLI wallet for one-shell-command agent payments (x402 + MPP)"
  homepage "https://agentscore.sh"
  url "${URL}"
  sha256 "${SHA}"
  license "MIT"

  depends_on "node"

  def install
    system "npm", "install", *Language::Node.std_npm_args(libexec)
    bin.install_symlink Dir["#{libexec}/bin/*"]
  end

  test do
    assert_match(/\d+\.\d+\.\d+/, shell_output("#{bin}/agentscore-pay --version"))
  end
end
