{
  "name": "@agent-score/pay",
  "version": "0.1.0",
  "description": "CLI wallet for one-shell-command agent payments across x402 (Base, Solana) and MPP (Tempo)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agentscore-pay": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:binary:darwin-arm64": "bun build src/index.ts --compile --target=bun-darwin-arm64 --outfile dist/bin/agentscore-pay-darwin-arm64",
    "build:binary:darwin-x64": "bun build src/index.ts --compile --target=bun-darwin-x64 --outfile dist/bin/agentscore-pay-darwin-x64",
    "build:binary:linux-arm64": "bun build src/index.ts --compile --target=bun-linux-arm64 --outfile dist/bin/agentscore-pay-linux-arm64",
    "build:binary:linux-x64": "bun build src/index.ts --compile --target=bun-linux-x64 --outfile dist/bin/agentscore-pay-linux-x64",
    "build:binary:windows-x64": "bun build src/index.ts --compile --target=bun-windows-x64 --outfile dist/bin/agentscore-pay-windows-x64.exe",
    "build:binary:all": "bun run build:binary:darwin-arm64 && bun run build:binary:darwin-x64 && bun run build:binary:linux-arm64 && bun run build:binary:linux-x64 && bun run build:binary:windows-x64",
    "dev": "tsx src/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "agentscore",
    "x402",
    "mpp",
    "tempo",
    "cli",
    "wallet",
    "base",
    "solana",
    "usdc",
    "ai-agent",
    "agentic-payments",
    "eip-3009",
    "spl-token"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentscore/pay"
  },
  "homepage": "https://agentscore.sh",
  "bugs": {
    "url": "https://github.com/agentscore/pay/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@scure/bip39": "^2.2.0",
    "@solana-program/token": "^0.13.0",
    "@solana/kit": "^6.8.0",
    "@x402/core": "^2.10.0",
    "@x402/evm": "^2.10.0",
    "@x402/fetch": "^2.10.0",
    "@x402/svm": "^2.10.0",
    "commander": "^14.0.1",
    "ed25519-hd-key": "^1.3.0",
    "mppx": "^0.6.3",
    "picocolors": "^1.1.1",
    "qrcode-terminal": "^0.12.0",
    "viem": "^2.39.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.6.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@vitest/coverage-v8": "^4.1.5",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  }
}
