{
  "name": "@agent-score/x402",
  "version": "0.1.0",
  "description": "CLI wallet for one-shell-command x402 payments on Base and Solana",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agentscore-x402": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "agentscore",
    "x402",
    "cli",
    "wallet",
    "base",
    "solana",
    "usdc",
    "ai-agent",
    "agentic-payments",
    "eip-3009",
    "spl-token"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentscore/x402-cli"
  },
  "homepage": "https://agentscore.sh",
  "bugs": {
    "url": "https://github.com/agentscore/x402-cli/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "@solana/kit": "^6.8.0",
    "@solana-program/token": "^0.13.0",
    "@x402/core": "^2.10.0",
    "@x402/evm": "^2.10.0",
    "@x402/fetch": "^2.10.0",
    "@x402/svm": "^2.10.0",
    "commander": "^14.0.1",
    "qrcode-terminal": "^0.12.0",
    "viem": "^2.39.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.6.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@vitest/coverage-v8": "^4.1.5",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  }
}
